# ─────────────────────────────────────────────────────────
#  ForceHub Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Comma-separated Telegram user IDs with super admin access
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# Directory where data files are stored
# Default: /app/data  (Railway compatible)
# For local dev you can use: ./data
DATA_DIR=/app/data
